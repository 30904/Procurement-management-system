# Copy to .env.production before `npm run build` on the droplet or CI.
# Same-origin deployment (recommended): leave VITE_API_BASE_URL empty.

VITE_API_BASE_URL=
VITE_APP_ENV=production
VITE_APP_PUBLIC_URL=https://pms.idms-atp.com
VITE_APP_NAME=Procurement Management System
VITE_APP_SHORT_NAME=PMS
VITE_APP_VERSION=1.0.0
VITE_THEME_COLOR=#0F7C94
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=true

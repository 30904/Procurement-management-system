# Copy to .env on the DigitalOcean droplet (never commit real .env with secrets).

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/procurement
PORT=5020
NODE_ENV=production

JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Public site URL (used for CORS and optional links)
PUBLIC_APP_URL=https://pms.idms-atp.com
CORS_ORIGIN=https://pms.idms-atp.com

# Required when behind Nginx / load balancer
TRUST_PROXY=1

# Set to 0 if Nginx serves frontend/dist and only proxies /api to Node
SERVE_FRONTEND=0

# Optional override when SERVE_FRONTEND=1
# FRONTEND_DIST_PATH=/var/www/pms/frontend/dist
